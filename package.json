{
  "name": "usernolan",
  "license": "CC0-1.0",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "upgrade:force": "npx npm-check-updates -u",
    "dev": "vite",
    "dev:markup": "nodemon -x npx tsx -i src/index.ts -i src/images.ts src/build/html.ts",
    "build:markup": "npx tsx src/build/html.ts",
    "release:markup": "npx tsx src/build/html.ts --release",
    "build:css": "postcss src/*.css --use autoprefixer --replace --no-map",
    "build:images": "npx tsx src/build/images.ts",
    "build": "tsc && npm run build:css && npm run release:markup && vite build",
    "preview": "vite preview",
    "clean": "npx rimraf dist"
  },
  "devDependencies": {
    "@thi.ng/hiccup": "^5.3.37",
    "@thi.ng/transducers": "^9.6.23",
    "@types/js-beautify": "^1.14.3",
    "@types/node": "^25.2.3",
    "autoprefixer": "^10.4.24",
    "image-size": "^2.0.2",
    "js-beautify": "^1.15.4",
    "nodemon": "^3.1.11",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
